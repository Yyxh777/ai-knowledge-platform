<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.springblade.modules.system.mapper.LevelMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="levelResultMap" type="org.springblade.modules.system.pojo.entity.LevelEntity">
        <result column="level_code" property="levelCode"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <select id="selectLevelPage" resultMap="levelResultMap">
        select * from aikp_level where is_deleted = 0
    </select>

    <select id="exportLevel" resultType="org.springblade.modules.system.excel.LevelExcel">
        SELECT * FROM aikp_level ${ew.customSqlSegment}
    </select>

</mapper>
