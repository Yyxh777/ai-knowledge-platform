# 复制本文件为 .env，填入真实值后启动服务
# .env 文件已加入 .gitignore，不会提交到代码仓库

# ============= LLM / OpenAI Compatible API =============
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============= Milvus =============
MILVUS_URI=http://192.168.8.104:19530
MILVUS_COLLECTION_NAME=document_collection

# ============= Redis（会话记忆） =============
REDIS_URL=redis://localhost:6379
# 会话历史在 Redis 中的过期时间（秒），默认 1 天
REDIS_TTL_SEC=86400

# ============= Java 服务配置 =============
JAVA_SERVICE_URL=http://localhost:8081
TOKEN_VALIDATE_ENDPOINT=/blade-system/user/info
# HTTP 请求超时时间（秒）
JAVA_SERVICE_TIMEOUT=5.0
# BladeX 客户端凭证：base64(client_id:client_secret)，默认 saber3:saber3_secret
JAVA_CLIENT_CREDENTIALS=Basic c2FiZXIzOnNhYmVyM19zZWNyZXQ=
# BladeX 专用请求标识，一般不需要修改
JAVA_REQUESTED_WITH=BladeHttpRequest

# ============= 认证配置 =============
TOKEN_CACHE_TTL=300
ENABLE_TOKEN_CACHE=true

# ============= MySQL（个人数据查询） =============
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=blade

# ============= 服务启动配置 =============
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ============= 日志配置 =============
LOG_LEVEL=INFO
